meta {
  name: 2_Login
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/v1/auth/session
  body: json
  auth: none
}

body:json {
  {
    "email": "user@corporate.com",
    "password": "SecurePassword123"
  }
}

tests {
  test("Should return 200 OK and a JWT Token", function() {
    expect(res.getStatus()).to.equal(200);
    expect(res.getBody()).to.have.property("token");
  });
}