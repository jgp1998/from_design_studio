tests {
  test("BID-003: HTTP 200, successfully accepted", function() {
    expect(res.getStatus()).to.equal(200);
    expect(res.getBody().ok).to.be.true;
    expect(res.getBody().message).to.equal("Bid accepted and others rejected");
  });
}
