meta {
  name: AUTH-002_Login
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/api/v1/auth/session
  body: json
  auth: none
}

body:json {
  {
    "email": "qa_client@test.com",
    "password": "Password123"
  }
}

tests {
  test("AUTH-002: Returns 201 Created and JWT token", function() {
    expect(res.getStatus()).to.equal(201);
    expect(res.getBody().token).to.be.a('string');
    bru.setEnvVar("client_token", res.getBody().token);
  });
}
