meta {
  name: AUTH-002_Login
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/api/v1/auth/session
  body: json
  auth: none
}

body:json {
  {
    "email": "qa_client@test.com",
    "password": "Password123"
  }
}

tests {
  test("AUTH-002: Returns 200 OK and JWT token", function() {
    expect(res.getStatus()).to.equal(200);
    expect(res.getBody().accessToken).to.be.a('string');
  });
}
